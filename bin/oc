#!/usr/bin/env bash
# =============================================================================
# oc — OpenCode with Claude Max Proxy launcher
#
# Starts the Claude Max proxy in the background, waits for it to be healthy,
# then launches OpenCode pointed at the proxy. Cleans up on exit.
#
# Usage:
#   oc              # TUI mode
#   oc web          # Web UI on port 4096
#   oc [args...]    # Pass any args to opencode
#   oc --help       # Show help
# =============================================================================

set -e

GREEN='\033[0;32m'
BLUE='\033[0;34m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
MUTED='\033[0;2m'
NC='\033[0m'

info()  { echo -e "${BLUE}[oc]${NC} $1"; }
ok()    { echo -e "${GREEN}[oc]${NC} $1"; }
warn()  { echo -e "${YELLOW}[oc]${NC} $1"; }
fail()  { echo -e "${RED}[oc]${NC} $1"; exit 1; }

# --- Help ---
if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    echo "oc — OpenCode with Claude Max Proxy"
    echo ""
    echo "Usage:"
    echo "  oc              Start OpenCode in TUI mode"
    echo "  oc web          Start OpenCode web UI (port 4096)"
    echo "  oc update       Update all components to latest versions"
    echo "  oc [args...]    Pass any arguments to opencode"
    echo "  oc --help       Show this help"
    echo "  oc --version    Show component versions"
    echo ""
    echo "Environment variables:"
    echo "  CLAUDE_PROXY_PORT       Proxy port (default: random available port)"
    echo "  CLAUDE_PROXY_WORKDIR    Working directory for proxy (default: \$PWD)"
    echo "  OC_SKIP_AUTH_CHECK      Set to 1 to skip Claude auth check"
    echo ""
    echo "Examples:"
    echo "  oc                      # Start TUI in current directory"
    echo "  oc web                  # Start web UI on http://localhost:4096"
    echo "  cd ~/my-project && oc   # Work on a specific project"
    exit 0
fi

# --- Update ---
if [[ "${1:-}" == "update" ]]; then
    info "Detecting package manager..."

    pkg_manager=""
    pkg_update_global=""

    if command -v bun &>/dev/null; then
        pkg_manager="bun"
        pkg_update_global="bun install -g"
    elif command -v npm &>/dev/null; then
        pkg_manager="npm"
        pkg_update_global="npm install -g"
    elif command -v pnpm &>/dev/null; then
        pkg_manager="pnpm"
        pkg_update_global="pnpm install -g"
    elif command -v yarn &>/dev/null; then
        pkg_manager="yarn"
        pkg_update_global="yarn global add"
    else
        fail "No supported package manager found. Install one of: bun, npm, pnpm, yarn"
    fi

    ok "Using $pkg_manager"

    PACKAGES=("@anthropic-ai/claude-code" "opencode-ai" "opencode-claude-max-proxy")
    BINS=("claude" "opencode" "claude-max-proxy")
    LABELS=("Claude Code CLI" "OpenCode" "Claude Max Proxy")

    # Collect current versions
    echo ""
    info "Current versions:"
    old_versions=()
    for i in "${!BINS[@]}"; do
        ver=$("${BINS[$i]}" --version 2>/dev/null || echo "not installed")
        old_versions+=("$ver")
        echo "  ${LABELS[$i]}: $ver"
    done

    # Run the update
    echo ""
    info "Updating all components..."
    for i in "${!PACKAGES[@]}"; do
        info "Updating ${LABELS[$i]}..."
        if $pkg_update_global "${PACKAGES[$i]}" 2>&1 | tail -3; then
            ok "${LABELS[$i]} updated"
        else
            warn "Failed to update ${LABELS[$i]}. Try manually: $pkg_update_global ${PACKAGES[$i]}"
        fi
    done

    # Show new versions
    echo ""
    info "Updated versions:"
    for i in "${!BINS[@]}"; do
        new_ver=$("${BINS[$i]}" --version 2>/dev/null || echo "not installed")
        if [[ "$new_ver" != "${old_versions[$i]}" ]]; then
            ok "${LABELS[$i]}: ${old_versions[$i]} -> $new_ver"
        else
            echo "  ${LABELS[$i]}: $new_ver (unchanged)"
        fi
    done

    # Also update the oc launcher itself from GitHub
    echo ""
    info "Updating oc launcher..."
    OC_INSTALL_DIR="$HOME/.opencode/bin"
    OC_LAUNCHER_URL="https://raw.githubusercontent.com/ianjwhite99/opencode-with-claude/main/bin/oc"
    if curl -fsSL "$OC_LAUNCHER_URL" -o "$OC_INSTALL_DIR/oc.tmp" 2>/dev/null; then
        chmod 755 "$OC_INSTALL_DIR/oc.tmp"
        mv "$OC_INSTALL_DIR/oc.tmp" "$OC_INSTALL_DIR/oc"
        ok "oc launcher updated"
    else
        warn "Could not update oc launcher (network error or not installed via installer)"
    fi

    echo ""
    ok "Update complete!"
    exit 0
fi

# --- Update ---
if [[ "${1:-}" == "update" ]]; then
    info "Detecting package manager..."

    pkg_manager=""
    pkg_update_global=""

    if command -v bun &>/dev/null; then
        pkg_manager="bun"
        pkg_update_global="bun install -g"
    elif command -v npm &>/dev/null; then
        pkg_manager="npm"
        pkg_update_global="npm install -g"
    elif command -v pnpm &>/dev/null; then
        pkg_manager="pnpm"
        pkg_update_global="pnpm install -g"
    elif command -v yarn &>/dev/null; then
        pkg_manager="yarn"
        pkg_update_global="yarn global add"
    else
        fail "No supported package manager found. Install one of: bun, npm, pnpm, yarn"
    fi

    ok "Using $pkg_manager"

    PACKAGES=("@anthropic-ai/claude-code" "opencode-ai" "opencode-claude-max-proxy")
    BINS=("claude" "opencode" "claude-max-proxy")
    LABELS=("Claude Code CLI" "OpenCode" "Claude Max Proxy")

    # Collect current versions
    echo ""
    info "Current versions:"
    old_versions=()
    for i in "${!BINS[@]}"; do
        ver=$("${BINS[$i]}" --version 2>/dev/null || echo "not installed")
        old_versions+=("$ver")
        echo "  ${LABELS[$i]}: $ver"
    done

    # Run the update
    echo ""
    info "Updating all components..."
    for i in "${!PACKAGES[@]}"; do
        info "Updating ${LABELS[$i]}..."
        if $pkg_update_global "${PACKAGES[$i]}" 2>&1 | tail -3; then
            ok "${LABELS[$i]} updated"
        else
            warn "Failed to update ${LABELS[$i]}. Try manually: $pkg_update_global ${PACKAGES[$i]}"
        fi
    done

    # Show new versions
    echo ""
    info "Updated versions:"
    for i in "${!BINS[@]}"; do
        new_ver=$("${BINS[$i]}" --version 2>/dev/null || echo "not installed")
        if [[ "$new_ver" != "${old_versions[$i]}" ]]; then
            ok "${LABELS[$i]}: ${old_versions[$i]} -> $new_ver"
        else
            echo "  ${LABELS[$i]}: $new_ver (unchanged)"
        fi
    done

    # Also update the oc launcher itself from GitHub
    echo ""
    info "Updating oc launcher..."
    OC_INSTALL_DIR="$HOME/.opencode/bin"
    OC_LAUNCHER_URL="https://raw.githubusercontent.com/ianjwhite99/opencode-with-claude/main/bin/oc"
    if curl -fsSL "$OC_LAUNCHER_URL" -o "$OC_INSTALL_DIR/oc.tmp" 2>/dev/null; then
        chmod 755 "$OC_INSTALL_DIR/oc.tmp"
        mv "$OC_INSTALL_DIR/oc.tmp" "$OC_INSTALL_DIR/oc"
        ok "oc launcher updated"
    else
        warn "Could not update oc launcher (network error or not installed via installer)"
    fi

    echo ""
    ok "Update complete!"
    exit 0
fi

# --- Find real binaries (skip Docker wrappers from this repo) ---
find_real_bin() {
    local name="$1"
    local IFS=':'
    for dir in $PATH; do
        local candidate="$dir/$name"
        if [[ -x "$candidate" ]]; then
            # Skip Docker wrapper scripts (small shell scripts with "docker exec")
            # Only check text files under 1KB — real binaries are much larger
            if [[ -f "$candidate" ]] && [[ $(wc -c < "$candidate" 2>/dev/null || echo 99999) -lt 1024 ]] \
                && head -1 "$candidate" 2>/dev/null | grep -q "^#!" \
                && grep -q "docker exec" "$candidate" 2>/dev/null; then
                continue  # Skip this Docker wrapper
            fi
            echo "$candidate"
            return
        fi
    done
    echo "$name"
}

CLAUDE_BIN="$(find_real_bin claude)"
OPENCODE_BIN="$(find_real_bin opencode)"
PROXY_BIN="$(find_real_bin claude-max-proxy)"

# --- Preflight checks ---
[[ -x "$CLAUDE_BIN" ]] || fail "Claude Code CLI not found. Run: npm install -g @anthropic-ai/claude-code"
[[ -x "$OPENCODE_BIN" ]] || fail "OpenCode not found. Run: npm install -g opencode-ai"
[[ -x "$PROXY_BIN" ]] || fail "claude-max-proxy not found. Run: npm install -g opencode-claude-max-proxy"

# --- Version ---
if [[ "${1:-}" == "--version" ]] || [[ "${1:-}" == "-v" ]]; then
    echo "oc launcher (opencode-with-claude)"
    echo ""
    echo -n "  opencode:         "
    "$OPENCODE_BIN" --version 2>/dev/null || echo "not found"
    echo -n "  claude-max-proxy: "
    "$PROXY_BIN" --version 2>/dev/null || echo "not found"
    echo -n "  claude:           "
    "$CLAUDE_BIN" --version 2>/dev/null || echo "not found"
    exit 0
fi

# --- Check authentication ---
if [[ "${OC_SKIP_AUTH_CHECK:-}" != "1" ]]; then
    if ! "$CLAUDE_BIN" auth status 2>&1 | grep -q '"loggedIn": true'; then
        fail "Claude not authenticated. Run: claude login"
    fi
fi

# --- Pick a port ---
if [[ -n "${CLAUDE_PROXY_PORT:-}" ]]; then
    PORT="$CLAUDE_PROXY_PORT"
else
    PORT=$(node -e "const s = require('net').createServer(); s.listen(0, '127.0.0.1', () => { console.log(s.address().port); s.close() })" 2>/dev/null \
      || echo $((RANDOM + 10000)))
fi

# --- Start proxy in background ---
info "Starting proxy on port $PORT..."
CLAUDE_PROXY_PORT=$PORT \
CLAUDE_PROXY_PASSTHROUGH=1 \
CLAUDE_PROXY_WORKDIR="${CLAUDE_PROXY_WORKDIR:-$PWD}" \
  "$PROXY_BIN" > /dev/null 2>&1 &
PROXY_PID=$!

cleanup() {
    info "Shutting down proxy (PID $PROXY_PID)..."
    kill $PROXY_PID 2>/dev/null
    wait $PROXY_PID 2>/dev/null
}
trap cleanup EXIT INT TERM

# --- Wait for health ---
for i in $(seq 1 100); do
    if curl -sf "http://127.0.0.1:$PORT/health" > /dev/null 2>&1; then
        ok "Proxy ready on port $PORT"
        break
    fi
    if ! kill -0 $PROXY_PID 2>/dev/null; then
        fail "Proxy failed to start. Is Claude authenticated? Run: claude login"
    fi
    sleep 0.1
done

if ! curl -sf "http://127.0.0.1:$PORT/health" > /dev/null 2>&1; then
    fail "Proxy didn't become healthy within 10 seconds"
fi

# --- Launch OpenCode ---
info "Launching OpenCode..."
ANTHROPIC_API_KEY=dummy \
ANTHROPIC_BASE_URL="http://127.0.0.1:$PORT" \
  "$OPENCODE_BIN" "$@"
